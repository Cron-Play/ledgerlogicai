{
  "expo": {
    "name": "build-an-ai-chatbot-",
    "slug": "build-an-ai-chatbot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-dua.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-dua.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-dua.png",
        "backgroundColor": "#000000"
      },
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "buildanaichatbot",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://sjejmczpu6x623pndtw9m2wu4zvha7bq.app.specular.dev"
    }
  }
}